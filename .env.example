# ──────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in what you have. Everything has a sane
# default; the only thing you *need* for online mode is GROQ_API_KEY.
# ──────────────────────────────────────────────────────────────────────────

# LLM provider: "groq" (free hosted, default) or "ollama" (fully offline)
LLM_PROVIDER=groq

# --- Groq (https://console.groq.com — free, no credit card) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Ollama (offline fallback: `ollama pull llama3.1:8b`) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- Embeddings / reranker (local, downloaded once from HuggingFace) ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Observability (optional — leave blank to disable, pipeline still runs) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
